# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clienthub

# JWT Secret (ВАЖНО: Измените на случайную строку в production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=5000

# CORS (разделяйте запятыми)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Node Environment
NODE_ENV=development
