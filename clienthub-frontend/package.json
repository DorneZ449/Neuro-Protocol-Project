{
  "name": "clienthub-frontend",
  "description": "КлиентХаб (ClientHub) — CRM система для управления клиентами",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
